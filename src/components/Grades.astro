---
interface GradeCard {
  level: number;
  label: string;
  progress: number;
  badge?: 'Nuevo' | 'Popular' | 'Próximamente' | null;
  classCount: number;
  ctaLabel: string;
  ctaHref: string;
}

interface GradesProps {
  heading: string;
  subheading: string;
  grades: GradeCard[];
}

const { heading, subheading, grades } = Astro.props;

// Badge styles
const badgeStyles: Record<string, { bg: string; text: string }> = {
  'Nuevo': { bg: 'bg-secondary/10', text: 'text-secondary' },
  'Popular': { bg: 'bg-accent/10', text: 'text-accent' },
  'Próximamente': { bg: 'bg-slate-100', text: 'text-slate-600' },
};
---

<section class="py-16 lg:py-24 bg-slate-50" id="grades" aria-labelledby="grades-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 lg:mb-16">
      <h2 id="grades-heading" class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4 reveal">{heading}</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto reveal" style="transition-delay: 100ms;">
        {subheading}
      </p>
    </div>

    <!-- Grades Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
      {grades.map((grade, index) => {
        const badge = grade.badge ? badgeStyles[grade.badge] : null;
        return (
          <div
            class="card-lift bg-white rounded-2xl p-5 lg:p-6 border border-slate-100 shadow-sm reveal"
            style={`transition-delay: ${index * 75}ms;`}
          >
            <!-- Header -->
            <div class="flex items-start justify-between mb-4">
              <div>
                <p class="text-3xl lg:text-4xl font-bold text-primary mb-1">{grade.level}</p>
                <p class="text-sm text-slate-600">{grade.label}</p>
              </div>
              {badge && (
                <span class={`inline-block px-2.5 py-1 rounded-full text-xs font-medium ${badge.bg} ${badge.text}`}>
                  {grade.badge}
                </span>
              )}
            </div>

            <!-- Progress Bar -->
            <div class="mb-4">
              <div class="flex justify-between text-xs text-slate-500 mb-1.5">
                <span>Contenido disponible</span>
                <span>{grade.progress}%</span>
              </div>
              <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
                <div
                  class="h-full bg-primary rounded-full transition-all duration-500"
                  style={`width: ${grade.progress}%;`}
                ></div>
              </div>
            </div>

            <!-- Class Count -->
            <p class="text-sm text-slate-500 mb-4">
              <span class="font-medium text-slate-700">{grade.classCount}</span> clases disponibles
            </p>

            <!-- CTA -->
            <a
              href={grade.ctaHref}
              class="block w-full text-center px-4 py-2.5 rounded-lg text-sm font-medium text-primary border border-primary/20 hover:bg-primary hover:text-white hover:border-primary transition-all duration-200"
            >
              {grade.ctaLabel}
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>
