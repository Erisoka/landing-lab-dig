---
interface Material {
  name: string;
  icon: string;
}

interface ClassPreviewProps {
  title: string;
  grade: string;
  duration: string;
  activities: string[];
  materials: Material[];
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
  headerGradient?: string;
}

const {
  title,
  grade,
  duration,
  activities,
  materials,
  primaryCta,
  secondaryCta,
  headerGradient = "linear-gradient(135deg, var(--color-primary), #3B82F6)"
} = Astro.props;

// Icon mapping for Material Symbols
const iconMap: Record<string, string> = {
  'laptop': 'laptop',
  'video': 'videocam',
  'document': 'description',
  'projector': 'smart_display',
  'robot': 'smart_toy',
  'code': 'code',
  'folder': 'folder',
  'pencil': 'edit',
  'book': 'menu_book',
};

function getIconCode(iconName: string): string {
  return iconMap[iconName] || 'check_circle';
}
---

<section class="py-16 lg:py-24 bg-white" id="class-preview">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Class Preview Card -->
    <div class="card-lift rounded-3xl overflow-hidden shadow-xl reveal">
      <!-- Header with Gradient -->
      <div
        class="px-6 lg:px-10 py-8 lg:py-12 text-white"
        style={`background: ${headerGradient};`}
      >
        <!-- Badge and Meta -->
        <div class="flex flex-wrap items-center gap-4 mb-6">
          <span class="inline-block px-3 py-1 bg-white/20 backdrop-blur rounded-full text-sm font-medium">
            {grade}
          </span>
          <span class="inline-flex items-center text-sm text-white/90">
            <span class="material-symbols-outlined text-lg mr-1">schedule</span>
            {duration}
          </span>
        </div>

        <!-- Title -->
        <h2 class="text-2xl lg:text-3xl font-bold mb-4">{title}</h2>

        <!-- Objective -->
        <p class="text-white/90 text-lg">
          Los estudiantes aprenderán a crear sus primeras animaciones utilizando herramientas de programación visual.
        </p>
      </div>

      <!-- Body -->
      <div class="px-6 lg:px-10 py-8 bg-white">
        <div class="grid lg:grid-cols-2 gap-8">
          <!-- Activities -->
          <div>
            <h3 class="text-lg font-semibold text-slate-900 mb-4 flex items-center">
              <span class="material-symbols-outlined text-secondary mr-2">check_circle</span>
              Actividades
            </h3>
            <ul class="space-y-3">
              {activities.map((activity) => (
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-secondary mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-slate-700">{activity}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Materials -->
          <div>
            <h3 class="text-lg font-semibold text-slate-900 mb-4 flex items-center">
              <span class="material-symbols-outlined text-accent mr-2">folder_open</span>
              Materiales
            </h3>
            <ul class="space-y-3">
              {materials.map((material) => (
                <li class="flex items-center">
                  <span class="material-symbols-outlined text-slate-400 mr-3">{getIconCode(material.icon)}</span>
                  <span class="text-slate-700">{material.name}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href={primaryCta.href}
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl text-base font-semibold text-white primary-gradient hover:scale-105 hover:shadow-lg transition-all duration-200"
          >
            <span class="material-symbols-outlined mr-2">description</span>
            {primaryCta.label}
          </a>
          <a
            href={secondaryCta.href}
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl text-base font-semibold text-primary border-2 border-primary hover:bg-primary hover:text-white transition-all duration-200"
          >
            {secondaryCta.label}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
