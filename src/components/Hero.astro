---
import { Image } from 'astro:assets';

interface HeroProps {
  headline: string;
  subheadline: string;
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
  mockupImage: any;
  mockupAlt: string;
}

const { headline, subheadline, primaryCta, secondaryCta, mockupImage, mockupAlt } = Astro.props;
---

<section class="relative pt-24 lg:pt-32 pb-16 lg:pb-24 bg-white hero-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text Content -->
      <div class="text-center lg:text-left">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 leading-tight mb-6 reveal">
          {headline}
        </h1>
        <p class="text-lg sm:text-xl text-slate-600 max-w-xl mx-auto lg:mx-0 mb-8 reveal" style="transition-delay: 100ms;">
          {subheadline}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start reveal" style="transition-delay: 200ms;">
          <a
            href={primaryCta.href}
            class="inline-flex items-center justify-center px-8 py-4 rounded-xl text-base font-semibold text-white primary-gradient hover:scale-105 hover:shadow-xl transition-all duration-200"
          >
            {primaryCta.label}
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href={secondaryCta.href}
            class="inline-flex items-center justify-center px-8 py-4 rounded-xl text-base font-semibold text-primary border-2 border-primary hover:bg-primary hover:text-white transition-all duration-200"
          >
            {secondaryCta.label}
          </a>
        </div>
      </div>

      <!-- Mockup Image -->
      <div class="relative reveal" style="transition-delay: 300ms;">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
          <Image
            src={mockupImage}
            alt={mockupAlt}
            class="w-full h-auto object-cover aspect-[4/3]"
            loading="eager"
          />
          <!-- Decorative blob -->
          <div class="absolute -top-10 -right-10 w-40 h-40 bg-secondary/10 rounded-full blur-3xl -z-10"></div>
          <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl -z-10"></div>
        </div>
      </div>
    </div>
  </div>
</section>
