---
import { Image } from 'astro:assets';

interface Institution {
  name: string;
  logoUrl: any;
}

interface Stat {
  value: string;
  label: string;
}

interface TrustBarProps {
  institutions: Institution[];
  stats: Stat[];
}

const { institutions, stats } = Astro.props;
---

<section class="bg-[#F1F5F9] py-12 lg:py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Stats -->
    <div class="flex flex-wrap justify-center gap-8 lg:gap-16 mb-10" aria-label="+500 instituciones educativas">
      {stats.map((stat) => (
        <div class="text-center">
          <p class="text-3xl lg:text-4xl font-bold text-primary mb-1">{stat.value}</p>
          <p class="text-sm text-slate-600">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Institution Logos -->
    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-12">
      {institutions.map((institution) => (
        <div class="grayscale opacity-100 contrast-125 hover:grayscale-0 transition-all duration-300">
          <Image
            src={institution.logoUrl}
            alt={institution.name}
            class="h-24 lg:h-32 max-w-[280px] w-auto object-contain mix-blend-darken scale-125"
            loading="eager"
          />
        </div>
      ))}
    </div>
  </div>
</section>
