---
interface ContentColumn {
  type: 'guion' | 'guia' | 'diapositiva';
  title: string;
  description: string;
  previewText?: string;
  ctaLabel: string;
  ctaHref: string;
}

interface ClassContentProps {
  heading: string;
  columns: ContentColumn[];
}

const { heading, columns } = Astro.props;

// Icon mapping
const iconMap: Record<string, string> = {
  'guion': 'menu_book',
  'guia': 'description',
  'diapositiva': 'slideshow',
};

function getIconCode(type: string): string {
  return iconMap[type] || 'check_circle';
}

// Type labels in Spanish
const typeLabels: Record<string, string> = {
  'guion': 'Guion de Clase',
  'guia': 'Guía Docente',
  'diapositiva': 'Diapositivas',
};
---

<section class="py-16 lg:py-24 bg-white" id="content" aria-labelledby="content-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 lg:mb-16">
      <h2 id="content-heading" class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4 reveal">{heading}</h2>
    </div>

    <!-- Columns Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {columns.map((column, index) => (
        <div
          class="group border border-slate-200 rounded-2xl p-6 lg:p-8 hover:border-primary hover:shadow-lg transition-all duration-300 reveal"
          style={`transition-delay: ${index * 100}ms;`}
        >
          <!-- Icon -->
          <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-colors duration-300">
            <span class="material-symbols-outlined text-primary text-2xl">
              {getIconCode(column.type)}
            </span>
          </div>

          <!-- Type Label -->
          <p class="text-sm font-medium text-primary mb-2">{typeLabels[column.type]}</p>

          <!-- Title -->
          <h3 class="text-xl font-semibold text-slate-900 mb-3">{column.title}</h3>

          <!-- Description -->
          <p class="text-slate-600 mb-4">{column.description}</p>

          <!-- Preview Text -->
          {column.previewText && (
            <div class="mb-6 p-4 bg-slate-50 rounded-xl">
              <p class="text-sm text-slate-500 italic">{column.previewText}</p>
            </div>
          )}

          <!-- CTA -->
          <a
            href={column.ctaHref}
            class="inline-flex items-center text-primary font-medium hover:text-[#1E40af] transition-colors duration-200 group-hover:underline"
          >
            {column.ctaLabel}
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
