---
import { Image } from 'astro:assets';

interface Feature {
  icon: string;
  text: string;
}

interface MakerLabProps {
  heading: string;
  subheading: string;
  image: any;
  imageAlt: string;
  features: Feature[];
  cta: { label: string; href: string };
  backgroundGradient?: string;
}

const {
  heading,
  subheading,
  image,
  imageAlt,
  features,
  cta,
  backgroundGradient = "linear-gradient(135deg, #0F172A, var(--color-primary))"
} = Astro.props;
---

<section class="relative py-16 lg:py-24 overflow-hidden" id="makerlab" style={`background: ${backgroundGradient};`} aria-labelledby="makerlab-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Content -->
      <div class="text-white reveal">
        <h2 id="makerlab-heading" class="text-3xl lg:text-4xl font-bold mb-4">{heading}</h2>
        <p class="text-lg text-white/80 mb-8">{subheading}</p>

        <!-- Features List -->
        <ul class="space-y-4 mb-10">
          {features.map((feature) => (
            <li class="flex items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-secondary flex items-center justify-center mr-3 mt-0.5">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-white/90">{feature.text}</span>
            </li>
          ))}
        </ul>

        <!-- CTA -->
        <a
          href={cta.href}
          class="inline-flex items-center px-8 py-4 rounded-xl text-base font-semibold text-[#0F172A] bg-white hover:bg-slate-100 hover:scale-105 hover:shadow-xl transition-all duration-200"
        >
          {cta.label}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      <!-- Image -->
      <div class="relative reveal" style="transition-delay: 200ms;">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
          <Image
            src={image}
            alt={imageAlt}
            class="w-full h-auto object-cover aspect-[4/3]"
            loading="lazy"
          />
        </div>
        <!-- Decorative elements -->
        <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-secondary/30 rounded-full blur-2xl"></div>
        <div class="absolute -top-6 -left-6 w-32 h-32 bg-[#3B82F6]/30 rounded-full blur-2xl"></div>
      </div>
    </div>
  </div>
</section>
